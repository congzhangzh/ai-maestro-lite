{
  "name": "ai-maestro-lite",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev --workspace @ai-maestro-lite/server\" \"npm run dev --workspace @ai-maestro-lite/desktop\"",
    "build": "npm run build --workspace @ai-maestro-lite/server && npm run build --workspace @ai-maestro-lite/desktop",
    "start:server": "npm run start --workspace @ai-maestro-lite/server",
    "start:desktop": "npm run start --workspace @ai-maestro-lite/desktop"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.14",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  }
}
